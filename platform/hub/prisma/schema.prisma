// CoteJS hub 데이터 모델. 초기 슬라이스는 arena가 쓰던 mock 형태를 그대로 담아
// 프론트 교체가 drop-in 되게 한다. (수치화 모델링은 후속 refine — engineering-notes 참고)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Problem {
  id              Int      @id
  title           String
  difficulty      String
  tier            String
  timeLimit       String
  memoryLimit     String
  submissionCount Int      @default(0)
  acceptedCount   Int      @default(0)
  tags            String[]
  aiGenerated     Boolean  @default(false)
  description     String
  inputDesc       String
  outputDesc      String
  starterCode     Json
  createdAt       DateTime @default(now())

  examples    Example[]
  submissions Submission[]
}

model Example {
  id        Int    @id @default(autoincrement())
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  problemId Int
  order     Int
  input     String
  output    String

  @@index([problemId])
}

model Submission {
  id           Int      @id @default(autoincrement())
  user         String
  problem      Problem  @relation(fields: [problemId], references: [id])
  problemId    Int
  problemTitle String
  result       String
  language     String
  time         String
  memory       String
  length       Int
  submittedAt  DateTime @default(now())

  @@index([problemId])
}
