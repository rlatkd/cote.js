{
  "name": "cotejs-platform",
  "private": true,
  "version": "0.0.0",
  "description": "CoteJS 제품 표면(TS): arena(Next) + hub(NestJS) + contracts(공유 타입)",
  "scripts": {
    "build:contracts": "pnpm --filter @cotejs/contracts build",
    "hub:generate": "pnpm --filter @cotejs/hub prisma:generate",
    "hub:migrate": "pnpm --filter @cotejs/hub prisma:migrate",
    "hub:seed": "pnpm --filter @cotejs/hub prisma:seed",
    "setup": "pnpm install && pnpm build:contracts && pnpm hub:generate && pnpm hub:migrate && pnpm hub:seed",
    "dev": "pnpm --parallel --filter @cotejs/hub --filter @cotejs/arena run dev",
    "dev:hub": "pnpm --filter @cotejs/hub dev",
    "dev:arena": "pnpm --filter @cotejs/arena dev"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "unrs-resolver",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "@nestjs/core"
    ]
  }
}
